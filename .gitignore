# Dépendances
backend/vendor/
frontend/node_modules/
frontend/dist/

# Environnement / secrets
backend/.env
# .env.docker est versionné (pas de secret réel, dev local)

# Base de données locale (SQLite)
backend/database/*.sqlite

# Logs & cache
backend/storage/logs/*
backend/storage/framework/cache/*

# Archives de contenu : les zips des formations sont versionnés (légers, prêts à
# l'import) ; seul le zip de démo (jetable) est ignoré.
content/demo.zip

# Captures d'écran / galeries de tests (artefacts générés par Playwright)
screenshots/

# Override Docker local (ports spécifiques à la machine) — ne pas versionner
docker-compose.override.yml

# Contenu assemblé par content/_tools/build.mjs (sortie générée, source = content/)
content/_dist/

# Divers
.DS_Store
